# 実デプロイ先の設定。`.deploy.env` にコピーして実値を書く（.deploy.env は gitignore 済み）。
#
#   cp .deploy.env.example .deploy.env
#   → WORKERS_SUBDOMAIN を自分の workers.dev サブドメインに書き換える
#   → npm run deploy
#
# 最も簡単: サブドメインだけ指定（3オリジンを issuer/verifier/web-wallet.<sub>.workers.dev に展開）
WORKERS_SUBDOMAIN=my-subdomain

# カスタムドメイン等で個別指定したい場合はこちらが優先される（任意）
#ISSUER_URL=https://issuer.example.com
#VERIFIER_ORIGIN=https://verifier.example.com
#WALLET_ORIGIN=https://wallet.example.com
