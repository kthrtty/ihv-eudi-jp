# 実デプロイ先の設定。`.deploy.env` にコピーして実値を書く（.deploy.env は gitignore 済み）。
#
#   cp .deploy.env.example .deploy.env
#   → WORKERS_SUBDOMAIN を自分の workers.dev サブドメインに書き換える
#   → npm run deploy
#
# 最も簡単: サブドメインだけ指定（3オリジンを issuer/verifier/web-wallet.<sub>.workers.dev に展開）
WORKERS_SUBDOMAIN=my-subdomain

# カスタムドメイン等で個別指定したい場合はこちらが優先される（任意）
#ISSUER_URL=https://issuer.example.com
#VERIFIER_ORIGIN=https://verifier.example.com
#WALLET_ORIGIN=https://wallet.example.com

# 認可 redirect_uri 許可リスト（オープンリダイレクタ対策）。
# 未指定なら ISSUER_URL/WALLET_ORIGIN から自動導出（issuer /demo/cb + wallet /oidc/cb）。
# 追加のローカル/検証オリジンを許可したいときだけ、空白区切りで明示指定する（任意）。
#REDIRECT_URI_ALLOWLIST=https://issuer.example.com/demo/cb https://wallet.example.com/oidc/cb http://localhost:8787/oidc/cb

# ウォレットのサーバ側 fetch 許可オリジン（SSRF 対策）。
# 未指定なら ISSUER_URL/VERIFIER_ORIGIN/WALLET_ORIGIN から自動導出。明示指定は空白区切り（任意）。
#SSRF_ALLOWED_ORIGINS=https://issuer.example.com https://verifier.example.com https://wallet.example.com
